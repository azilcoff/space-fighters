{
  "$schema": "https://opencode.ai/config.json",
    "permission":{
        "read": "allow",
        "write": "deny",
        "bash": {
            "*": "ask",
            "touch *": "deny",
            "ls  *": "allow",
            "* | grep *": "allow",
            "find *": "allow"
        }
    }
}